# Base URL of the AV1-Company API (see ../server). Used to fetch published
# CMS content (currently: the Gallery) at runtime — not baked into the build.
VITE_API_URL="http://localhost:4000/api/v1"

# WhatsApp click-to-chat number for the floating contact button (see
# src/config/contact.ts). Digits only, country code first, no '+'. Optional —
# falls back to COMPANY_INFO.phone (src/lib/seo.ts) if unset.
# VITE_WHATSAPP_NUMBER=355691234567

# Google Analytics 4 measurement ID (see src/lib/analytics.ts). Optional —
# analytics stays fully inert until this is set.
# VITE_GA_MEASUREMENT_ID=G-XXXXXXXXXX
