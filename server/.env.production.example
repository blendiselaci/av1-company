# Production environment template. Copy to `.env.production` on the deploy
# target (or paste these as dashboard env vars on Railway/Render) and replace
# every placeholder below — this file is committed as a template, never as
# real secrets.
#
# `env.ts` refuses to boot with NODE_ENV=production if any of the three
# secrets below are still set to their `.env.example` placeholder values, as
# a guardrail against accidentally deploying with dev secrets.

# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=4000
API_PREFIX=/api/v1

# ── Database (PostgreSQL) ───────────────────────────────────────────
# Neon: use the pooled connection string (works fine for Prisma's default
# connection handling) — copy it from the Neon dashboard as-is, it already
# includes `?sslmode=require`.
DATABASE_URL="postgresql://user:password@ep-example-12345.us-east-2.aws.neon.tech/av1_company?sslmode=require"

# ── JWT ──────────────────────────────────────────────────────────────
# Generate distinct, real random secrets — do not reuse across environments:
#   openssl rand -hex 64
JWT_ACCESS_SECRET="__REPLACE_WITH_A_REAL_64_BYTE_RANDOM_SECRET__"
JWT_REFRESH_SECRET="__REPLACE_WITH_A_DIFFERENT_REAL_64_BYTE_RANDOM_SECRET__"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

COOKIE_SECRET="__REPLACE_WITH_A_THIRD_REAL_64_BYTE_RANDOM_SECRET__"

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated, no trailing slashes. Only the real deployed frontend
# origins — never "*" (credentials: true CORS + wildcard origin is invalid
# and a real security hole if it were somehow accepted).
CORS_ORIGIN="https://av1-company.al,https://admin.av1-company.al"

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ── Cloudinary ───────────────────────────────────────────────────────
# From the Cloudinary dashboard (Settings → Access Keys). Never commit real
# values — this is a template only.
CLOUDINARY_CLOUD_NAME="__REPLACE_ME__"
CLOUDINARY_API_KEY="__REPLACE_ME__"
CLOUDINARY_API_SECRET="__REPLACE_ME__"
CLOUDINARY_UPLOAD_FOLDER="av1-company"

# ── Email notifications (contact form) ──────────────────────────────
# 'none' logs instead of sending (safe default). Set to 'resend' or 'smtp'
# once real credentials exist — see src/services/email.service.ts.
EMAIL_PROVIDER=none
EMAIL_FROM="AV1-Company <no-reply@av1-company.al>"
EMAIL_NOTIFY_TO="info@av1-company.al"
# RESEND_API_KEY="__REPLACE_ME__"
# SMTP_HOST="__REPLACE_ME__"
# SMTP_PORT=587
# SMTP_USER="__REPLACE_ME__"
# SMTP_PASSWORD="__REPLACE_ME__"

# ── Seed script (run once against production, then rotate both passwords
#    from inside the dashboard — see DEPLOYMENT.md) ─────────────────
SEED_ADMIN_EMAIL="admin@av1-company.al"
SEED_ADMIN_PASSWORD="__REPLACE_WITH_A_STRONG_TEMPORARY_PASSWORD__"
SEED_ADMIN_NAME="AV1 Admin"

SEED_EDITOR_EMAIL="editor@av1-company.al"
SEED_EDITOR_PASSWORD="__REPLACE_WITH_A_STRONG_TEMPORARY_PASSWORD__"
SEED_EDITOR_NAME="AV1 Editor"
