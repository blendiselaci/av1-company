# ── App ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=/api/v1

# ── Database (PostgreSQL via Prisma) ────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/av1_company?schema=public"

# ── JWT ──────────────────────────────────────────────────────────────
# Generate strong random secrets for production, e.g. `openssl rand -hex 64`
JWT_ACCESS_SECRET="replace-with-a-long-random-access-token-secret"
JWT_REFRESH_SECRET="replace-with-a-long-random-refresh-token-secret"
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Signs the httpOnly refresh-token cookie itself (separate from the JWT signature)
COOKIE_SECRET="replace-with-a-long-random-cookie-secret"

# ── CORS ─────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (the admin dashboard / public site)
CORS_ORIGIN="http://localhost:5173,http://localhost:3000"

# ── Rate limiting ────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
AUTH_RATE_LIMIT_MAX=10

# ── Cloudinary (placeholder — swap for real credentials before launch) ─
CLOUDINARY_CLOUD_NAME="av1-company-placeholder"
CLOUDINARY_API_KEY="placeholder-api-key"
CLOUDINARY_API_SECRET="placeholder-api-secret"
CLOUDINARY_UPLOAD_FOLDER="av1-company"

# ── Public-image watermark — see src/utils/watermark.ts ─────────────
# Overlays the AV1-Company logo (bottom-right, 50% opacity) on every public
# image at delivery time. Unset by default (no watermark). To turn it on:
# upload the logo to Cloudinary once as its own image asset (PNG, transparent
# background), then set this to that asset's public_id, e.g. "av1-company/watermark-logo".
# CLOUDINARY_WATERMARK_PUBLIC_ID=

# ── Email notifications (contact form) — 'none' just logs, see ──────
# src/services/email.service.ts. Swap in 'resend' or 'smtp' once real
# credentials exist; no code changes needed elsewhere.
EMAIL_PROVIDER=none
EMAIL_FROM="AV1-Company <no-reply@av1-company.al>"
EMAIL_NOTIFY_TO="info@av1-company.al"
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASSWORD=

# ── Telegram notifications (contact form) ───────────────────────────
# Instant "ping my phone" alert on every new inquiry, in addition to the
# email notification above and the durably-stored ContactMessage row.
# Both vars must be set or this just logs — see src/services/telegram.service.ts.
# Setup: message @BotFather on Telegram -> /newbot -> copy the token it gives you.
# Then message @userinfobot to get your own numeric chat id.
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# ── Seed script (initial accounts) ──────────────────────────────────
SEED_ADMIN_EMAIL="admin@av1-company.al"
SEED_ADMIN_PASSWORD="ChangeMe123!"
SEED_ADMIN_NAME="AV1 Admin"

SEED_EDITOR_EMAIL="editor@av1-company.al"
SEED_EDITOR_PASSWORD="ChangeMe123!"
SEED_EDITOR_NAME="AV1 Editor"
