# Production build-time config. Vite inlines VITE_* vars into the static
# bundle at build time — this isn't read at runtime, so it only matters when
# you actually run `npm run build` / `docker build`.
#
# Vercel: set this as a Project → Environment Variable (Production).
# Docker: pass as a build arg instead — `docker build --build-arg
#   VITE_API_URL=... .` (see admin/Dockerfile) — a plain .env file isn't
#   read during `docker build`.

VITE_API_URL="https://api.av1-company.al/api/v1"
